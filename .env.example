# --- Market Data Provider Configuration ---

# Interactive Brokers (TWS or Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# TradeStation API Credentials
# Get these from the TradeStation Developer Portal
TRADESTATION_API_KEY=your_api_key_here
TRADESTATION_API_SECRET=your_api_secret_here
TRADESTATION_ACCOUNT_ID=your_account_id_here

# --- Pipeline Settings ---
LOG_LEVEL=INFO
DATA_RETENTION_DAYS=365